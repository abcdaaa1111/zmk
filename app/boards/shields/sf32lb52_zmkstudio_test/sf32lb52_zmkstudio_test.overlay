#include <zephyr/dt-bindings/gpio/gpio.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

&pinctrl {
	usb_default: usb_default {
		group1 {
			pinmux = <PA35_ANALOG>, <PA36_ANALOG>;
			input-enable;
		};
	};
};

/ {
	chosen {
		zmk,kscan = &kscan_direct;
	};

	default_transform: keypad_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <2>;
		rows = <1>;
		map = < RC(0,0) RC(0,1) >;
	};

	default_layout: default_layout {
		compatible = "zmk,physical-layout";
		display-name = "Default";
		transform = <&default_transform>;
		keys
			= <&key_physical_attrs 100 100   0   0   0 0 0>
			, <&key_physical_attrs 100 100 100   0   0 0 0>
			;
	};

	kscan_direct: kscan_direct {
		compatible = "zmk,kscan-gpio-direct";
		input-gpios =
			<&gpioa_32_44 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
			<&gpioa_00_31 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
	};

	zephyr,user {
		pinctrl-0 = <&usb_default>;
		pinctrl-names = "default";
	};
};
